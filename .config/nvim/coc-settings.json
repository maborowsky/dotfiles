{
    "python.jediEnabled": false,
    "python.linting.enabled": true,
    "python.venvFolders": ["envs",".pyenv",".direnv"],
    "python.venvPath": "~/workspace/venv",
    "python.pythonPath": "~/workspace/venv/bin/python",
    "languageserver": {
        "golang": {
            "command": "gopls",
            "rootPatterns": ["go.mod"],
            "filetypes": ["go"]
        }
    }
}
